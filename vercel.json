{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/stock-analysis/:symbol",
      "destination": "/api/stock-analysis?symbol=:symbol"
    },
    {
      "source": "/api/market-data",
      "destination": "/api/market-data"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
